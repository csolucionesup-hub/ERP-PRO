# ─── Base de datos MySQL (Railway MySQL Plugin) ───────────────────────────────
# En Railway, copia los valores exactos del plugin MySQL en las variables de abajo
DB_HOST=your-railway-mysql-host.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=railway

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente — no es necesario configurarlo
PORT=3000

# ─── Seguridad ────────────────────────────────────────────────────────────────
SESSION_SECRET=cambiar_por_secreto_seguro_en_produccion
NODE_ENV=production
# Orígenes permitidos para CORS (separados por coma sin espacios)
ALLOWED_ORIGINS=http://localhost:3000

# ─── Negocio ──────────────────────────────────────────────────────────────────
# ID de la cuenta contable principal (Caja General Soles)
DEFAULT_ACCOUNT_ID=1
